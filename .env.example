# Database — choose one:
#
# Option A (default): Cloudflare D1
# No env vars needed — the DB binding in wrangler.toml handles the connection.
# For local dev with D1: wrangler dev (uses remote D1 preview DB automatically)
#
# Option B: Turso (set both vars and remove the [[d1_databases]] block in wrangler.toml)
NUXT_TURSO_URL=libsql://your-db-name.turso.io
NUXT_TURSO_AUTH_TOKEN=

# Better Auth
NUXT_BETTER_AUTH_SECRET=change-me-32-chars-minimum

# Cloudflare Images (optional)
NUXT_CLOUDFLARE_IMAGES_TOKEN=
NUXT_CLOUDFLARE_ACCOUNT_ID=
NUXT_CLOUDFLARE_IMAGES_DELIVERY_URL=

# Email provider: console | resend | brevo | zepto | smtp
NUXT_EMAIL_PROVIDER=console
NUXT_RESEND_API_KEY=
NUXT_BREVO_API_KEY=
NUXT_ZEPTO_API_KEY=
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=
NUXT_SMTP_PASS=

# Public (exposed to client)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
